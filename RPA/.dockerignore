*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# MyPy
.mypy_cache/

# Git
.git/
.gitignore

# Docker
docker/
Dockerfile*
docker-compose*.yml

# Documentation
docs/
*.md
!README.md

# Memory storage (large files)
memory_storage/
memory/

# Node.js (if any)
node_modules/

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.*
!.env.example
