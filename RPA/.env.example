# RPA - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# =============================================================================
# REQUIRED: GitHub Token for Docker Image Pull
# =============================================================================
# Create at: https://github.com/settings/tokens/new
# Required scope: read:packages
# Then run: echo YOUR_TOKEN | docker login ghcr.io -u BBRNGIT --password-stdin
GITHUB_TOKEN=

# =============================================================================
# OPTIONAL: HuggingFace Token for Training
# =============================================================================
# Create at: https://huggingface.co/settings/tokens
# Required for: Training from HuggingFace datasets
HUGGINGFACE_TOKEN=

# =============================================================================
# Security Settings
# =============================================================================
# IMPORTANT: Change this in production!
SECRET_KEY=rpa-secret-key-change-in-production

# =============================================================================
# CORS Settings
# =============================================================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost

# =============================================================================
# Data & Storage
# =============================================================================
# Path for LTM graph and EpisodicMemory persistence
LTM_DATA_PATH=/data

# =============================================================================
# Sandbox Settings
# =============================================================================
# Timeout for Python code execution (seconds)
SANDBOX_TIMEOUT=10

# =============================================================================
# Logging
# =============================================================================
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Environment mode: development, staging, production
ENVIRONMENT=production
